Text Analy
import java.util.*;
class P12{
 public static void main(String[] a){
  Scanner s=new Scanner(System.in);
  String t=s.nextLine().toLowerCase();
  int v=0,c=0;
  for(char ch:t.toCharArray()){
   if(ch>='a'&&ch<='z'){
    if("aeiou".indexOf(ch)!=-1) v++;
    else c++;
   }
  }
  System.out.println(v+" "+c);
 }
}
