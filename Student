Initialization System (Constructor Overloading)
class Student {
    String name; int age;
    Student(){ name="NoName"; age=0; }
    Student(String n){ name=n; age=0; }
    Student(String n,int a){ name=n; age=a; }

    public static void main(String[] args){
        Student s1=new Student();
        Student s2=new Student("Ram");
        Student s3=new Student("Sam",20);
        System.out.println(s3.name+" "+s3.age);
    }
}
