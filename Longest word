Sentence Analyzer (Longest word)

class LongestWord {
    public static void main(String[] args) {
        String s="Java is very powerful language";
        String[] w=s.split(" ");
        String longWord=w[0];
        for(String x:w){
            if(x.length()>longWord.length())
                longWord=x;
        }
        System.out.println(longWord);
    }
}
